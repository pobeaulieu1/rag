    {
      "name": "Run RAG (vanilla)",
      "type": "debugpy",
      "request": "launch",
      "program": "${workspaceFolder}/rag-vanilla.py",
      "python": "${workspaceFolder}/.venv/bin/python",
      "envFile": "${workspaceFolder}/.env",
      "console": "integratedTerminal"
    }
  ]
}
